# ========================================================
# SEAFLOWS TECHNOLOGIES - SHARED CONFIGURATION ENVIRONMENT
# ========================================================

# Setup Local Variables:
# Copy this file to '.env' at the root of your workspace for local development.

# --- SUPABASE CORE CONNECTION KEYS ---
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anonymous-public-key

# --- SERVICE PORT ---
PORT=3000

# ========================================================
# HOW AND WHERE TO TRACK SEPARATE DEPLOYMENT CONFIGURATIONS
# ========================================================
#
# Because your Customer Website (www.seaflowstech.com) and 
# Admin Dashboard (admin.seaflowstech.com) are built as separate front-ends
# connecting to the exact same Supabase backend database, you should configure 
# their environments relative to your hosting endpoints:
#
# --------------------------------------------------------
# 1. LOCAL DEVELOPMENT (.env.local, .env.development)
# --------------------------------------------------------
# Create custom environment files in each workspace instance:
#
# A) Customer Frontend Environment File (.env.customer)
#    VITE_SUPABASE_URL=https://[YOUR_SUPABASE_PROJECT].supabase.co
#    VITE_SUPABASE_ANON_KEY=[YOUR_PUBLIC_ANON_KEY]
#    VITE_SITE_ROLE=customer
#    VITE_REDIRECT_URL=https://www.seaflowstech.com
#
# B) Admin Frontend Environment File (.env.admin)
#    VITE_SUPABASE_URL=https://[YOUR_SUPABASE_PROJECT].supabase.co
#    VITE_SUPABASE_ANON_KEY=[YOUR_PUBLIC_ANON_KEY]
#    VITE_SITE_ROLE=admin
#    VITE_REDIRECT_URL=https://admin.seaflowstech.com
#
# --------------------------------------------------------
# 2. CLOUD PRODUCTION BUILD SERVICES (Vercel, Netlify, Cloud Run)
# --------------------------------------------------------
# To avoid storing sensitive keys in your Git Repository, configure your variables
# directly in the admin dashboard of your hosting provider:
#
# Step A: Navigate to your Customer Project Settings on your host (e.g. Vercel)
#         -> Environment Variables -> Add:
#         - Key: VITE_SUPABASE_URL | Value: [Your URL]
#         - Key: VITE_SUPABASE_ANON_KEY | Value: [Your Anon Key]
#
# Step B: Navigate to your Admin Project Settings on your host (e.g. Vercel)
#         -> Environment Variables -> Add:
#         - Key: VITE_SUPABASE_URL | Value: [Your URL]
#         - Key: VITE_SUPABASE_ANON_KEY | Value: [Your Anon Key]
#
